{
    "network": {
        "name": "testnet",
        "description": "catapult public test network"
    },

    "port": 3000,
    "protocol": "HTTPS",
    "sslKeyPath": "cert/key.pem",
    "sslCertificatePath": "cert/cert.pem",
    "crossDomain": {
        "allowedHosts": ["*"],
        "allowedMethods": ["GET", "POST", "PUT", "OPTIONS"]
    },

    "routeExtensions": [
        "light"
    ],

    "apiNode": {
        "host": "symbol-harvesting.rockbear.io",
        "port": 7900,
        "timeout": 1000,
        "tlsClientCertificatePath": "cert/node.crt.pem",
        "tlsClientKeyPath": "cert/node.key.pem",
        "tlsCaCertificatePath": "cert/ca.crt.pem",

        "inflationPropertyFilePath": "/",
        "networkPropertyFilePath": "/",
        "nodePropertyFilePath": "/"
    },

    "throttling": {
        "burst": 20,
        "rate": 5
    },

    "logging": {
        "console": {
            "formats": ["colorize", "simple"],

            "level": "verbose",
            "handleExceptions": true
        },
        "file": {
            "formats": ["prettyPrint"],

            "level": "verbose",
            "handleExceptions": true,

            "filename": "catapult-rest.log",
            "maxsize": 20971520,
            "maxFiles": 100
        }
    },

    "deployment": {
        "deploymentTool": "",
        "deploymentToolVersion": "",
        "lastUpdatedDate": ""
    }
}
